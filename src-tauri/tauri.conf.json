{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "OpenClawAnywhere",
  "version": "1.0.0",
  "identifier": "com.openclaw.anywhere",
  "build": {
    "frontendDist": "../public",
    "beforeBuildCommand": "npm run build:sidecar",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenClawAnywhere",
        "url": "desktop.html",
        "width": 420,
        "height": 720,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "OpenClawAnywhere - 运行中"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/cloudflared*"
    ],
    "externalBin": [
      "binaries/openclaw-gateway"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "autostart": null,
    "shell": {
      "open": true
    }
  }
}
